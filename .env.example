# Порт внутри контейнера (наружу см. docker-compose ports)
PORT=8080

# Почта (nodemailer) — заявки с форм
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
EMAIL_TO=admin@example.com

# Telegram — уведомления о заявках
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
