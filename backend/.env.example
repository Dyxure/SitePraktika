# Порт backend
PORT=8080

# Email (SMTP). Укажите параметры, чтобы заявки уходили на email.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
EMAIL_TO=admin@example.com

# Telegram (опционально). Если заполнить, заявки также уйдут в Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

